// Schema de base de datos - Iglesia Misión Panamericana Centro de Fe y Esperanza
// DB: PostgreSQL (Supabase free tier)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Rol {
  ADMIN
  PASTOR
  LIDER
}

enum EstadoCita {
  PENDIENTE
  CONFIRMADA
  CANCELADA
  COMPLETADA
}

model Usuario {
  id           Int      @id @default(autoincrement())
  nombre       String
  email        String   @unique
  passwordHash String
  rol          Rol      @default(LIDER)
  telefono     String?
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  citasComoPastor Cita[] @relation("PastorCitas")

  @@map("usuarios")
}

model Persona {
  id              Int       @id @default(autoincrement())
  nombres         String
  apellidos       String
  tipoDocumento   String? // CC, TI, RC, CE
  numeroDocumento String?
  telefono        String?
  email           String?
  barrio          String?
  direccion       String?
  fechaNacimiento DateTime?
  genero          String?
  estadoCivil     String?
  ministerio      String? // ej: Alabanza, Jóvenes, Niños, Damas, Varones
  rolIglesia      String? // ej: Miembro, Líder, Diácono, Visitante
  fechaIngreso    DateTime  @default(now())
  bautizado       Boolean   @default(false)
  fechaBautismo   DateTime?
  notas           String?
  activo          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  citas Cita[]

  @@map("personas")
}

model Servicio {
  id          Int      @id @default(autoincrement())
  nombre      String // ej: "Servicio Dominical", "Culto de Oración"
  diaSemana   String // "Domingo", "Lunes", ... "Sábado"
  horaInicio  String // "09:00"
  horaFin     String?
  lugar       String?
  descripcion String?
  imagenUrl   String? // imagen de portada
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  imagenes ServicioImagen[]

  @@map("servicios")
}

model ServicioImagen {
  id         Int      @id @default(autoincrement())
  servicioId Int
  servicio   Servicio @relation(fields: [servicioId], references: [id], onDelete: Cascade)
  url        String
  orden      Int      @default(0)
  createdAt  DateTime @default(now())

  @@map("servicio_imagenes")
}

model Evento {
  id          Int      @id @default(autoincrement())
  titulo      String
  descripcion String?
  fecha       DateTime
  horaInicio  String?
  horaFin     String?
  lugar       String?
  imagenUrl   String? // imagen de portada
  categoria   String   @default("Otro")
  // Categorías sugeridas: "Cumbre Ministerial", "Fiesta de Primicias",
  // "Juntos Bajo la Bendición de Dios", "Acción de Gracias",
  // "Ministerio M.I.A", "Ministerio M.J.P", "Vigilia", "Día del Padre",
  // "Día de la Madre", "Otro"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  imagenes EventoImagen[]

  @@map("eventos")
}

model EventoImagen {
  id        Int      @id @default(autoincrement())
  eventoId  Int
  evento    Evento   @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  url       String
  orden     Int      @default(0)
  createdAt DateTime @default(now())

  @@map("evento_imagenes")
}

model Cita {
  id                  Int        @id @default(autoincrement())
  personaId           Int?
  persona             Persona?   @relation(fields: [personaId], references: [id], onDelete: SetNull)
  nombreSolicitante   String
  telefonoSolicitante String
  emailSolicitante    String?
  pastorId            Int
  pastor              Usuario    @relation("PastorCitas", fields: [pastorId], references: [id])
  fecha               DateTime
  hora                String
  motivo              String?
  estado              EstadoCita @default(PENDIENTE)
  recordatorioEnviado Boolean  @default(false)
  notasInternas       String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  @@map("citas")
}

model Visita {
  id                 Int      @id @default(autoincrement())
  nombres            String
  apellidos          String
  email              String?
  telefono           String
  barrio             String?
  direccion          String?
  adicional          String?  // petición de oración / mensaje
  asisteOtraIglesia  String   // "Si" / "No"
  desearLlamada      String   // "Si" / "No"
  createdAt          DateTime @default(now())

  @@map("visitas")
}

model PresentacionBebe {
  id                Int      @id @default(autoincrement())
  nombreBebe        String
  fechaNacimiento   DateTime
  nombreMadre       String
  nombrePadre       String
  fechaPresentacion DateTime
  notas             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("presentaciones_bebe")
}
